rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);

      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.subscription.planId == 'free'
        && request.resource.data.quota.aiCredits == 3
        && request.resource.data.quota.speechMinutes == 10;

      allow update: if isOwner(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.subscription == resource.data.subscription
        && request.resource.data.quota.aiCredits <= resource.data.quota.aiCredits
        && request.resource.data.quota.speechMinutes <= resource.data.quota.speechMinutes
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['name', 'level', 'specialty', 'profile', 'quota', 'avatarUrl']);

      allow delete: if false;
    }

    match /progress/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && request.resource.data.uid == uid;
      allow update: if isOwner(uid)
        && resource.data.uid == uid
        && request.resource.data.uid == uid;
      allow delete: if false;
    }

    match /leaderboard/{uid} {
      allow read: if request.auth != null;
      allow create, update: if isOwner(uid)
        && request.resource.data.uid == uid;
      allow delete: if false;
    }
  }
}